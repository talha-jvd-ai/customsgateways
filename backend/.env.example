# CustomsGateways Pipeline Configuration

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-api-key-here

# PostgreSQL
DATABASE_URL=postgresql://hsuser:hspassword@localhost:5432/hsdb

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# API
API_HOST=0.0.0.0
API_PORT=8000

# Pipeline
UPLOAD_DIR=uploads
RESULTS_DIR=results

# LLM Model
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
